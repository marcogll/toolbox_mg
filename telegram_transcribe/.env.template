# API Key for Whisper transcription
# OpenAI: https://platform.openai.com/api-keys
# OpenRouter: https://openrouter.ai/keys (supports OpenAI Whisper + other models)
API_KEY=your_api_key_here

# API Base URL (leave empty for OpenAI default)
# For OpenRouter: https://openrouter.ai/api/v1
API_BASE_URL=

# Transcription method: "api" (OpenAI or OpenRouter)
TRANSCRIPTION_METHOD=api

# Model selection:
# OpenAI: whisper-1
# OpenRouter: openai/whisper-1 (or other whisper models available)
WHISPER_MODEL=whisper-1

# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
# ID del canal de origen (donde llegan videos/audios)
SOURCE_CHANNEL_ID=@tu_canal_o_id
# ID del grupo foro de destino (donde se envían las preguntas con botones)
TARGET_GROUP_ID=@tu_grupo_foro_o_id
# ID del topic en el grupo foro (message_thread_id)
TARGET_TOPIC_ID=1234
