# API Key for Whisper transcription
# OpenAI: https://platform.openai.com/api-keys
# OpenRouter: https://openrouter.ai/keys (supports OpenAI Whisper + other models)
API_KEY=your_api_key_here

# API Base URL (leave empty for OpenAI default)
# For OpenRouter: https://openrouter.ai/api/v1
API_BASE_URL=

# Transcription method: "api" (OpenAI or OpenRouter)
TRANSCRIPTION_METHOD=api

# Model selection:
# OpenAI: whisper-1
# OpenRouter: openai/whisper-1 (or other whisper models available)
WHISPER_MODEL=whisper-1
